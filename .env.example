# tap-noaa-gfs Configuration
# Copy this file to .env and adjust values as needed.
# No authentication required — GFS data is public.

# Data source: "nomads" (server-side filtered) or "aws_s3" (full GRIB2 files)
TAP_NOAA_GFS_SOURCE=nomads

# Required: First forecast run date to extract
TAP_NOAA_GFS_START_DATE=2026-03-01

# Optional: Last date (defaults to today UTC)
# TAP_NOAA_GFS_END_DATE=2026-03-13

# Cycles to extract (comma-separated): 00, 06, 12, 18
# TAP_NOAA_GFS_CYCLES=["00", "06", "12", "18"]

# Forecast hours to extract
# TAP_NOAA_GFS_FORECAST_HOURS=[0, 6, 12, 18, 24, 48, 72, 96, 120, 168, 240, 336]

# GRIB2 variables to extract
# TAP_NOAA_GFS_VARIABLES=["TMP", "UGRD", "VGRD", "APCP", "RH"]

# Grid step: 1=full 0.25° resolution, 4=1° resolution (reduces volume 16x)
TAP_NOAA_GFS_GRID_STEP=4

# Rate limit for NOMADS (requests per minute)
TAP_NOAA_GFS_MAX_REQUESTS_PER_MINUTE=20
